---
---
<div id="editorial-dashboard" class="relative w-full my-16 not-prose bg-[#FAF9F6] paper-texture p-4 md:p-8 overflow-hidden rounded-sm">
  
  <!-- Global Filter & Patterns -->
  <svg width="0" height="0" class="absolute pointer-events-none">
    <defs>
      <!-- Subtle organic hand tremor -->
      <filter id="hand-tremor" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" result="noise" />
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.5" xChannelSelector="R" yChannelSelector="G" />
      </filter>
      
      <!-- Hatching patterns -->
      <pattern id="hatch-dark" width="4" height="4" patternUnits="userSpaceOnUse">
        <line x1="0" y1="2" x2="4" y2="2" stroke="#6B6B6B" stroke-width="1" />
      </pattern>
      
      <pattern id="hatch-cyan" width="4" height="4" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
        <line x1="0" y1="2" x2="4" y2="2" stroke="#079AED" stroke-width="1" />
      </pattern>

      <pattern id="dots-cyan" width="8" height="8" patternUnits="userSpaceOnUse">
        <circle cx="4" cy="4" r="0.5" fill="#079AED" />
      </pattern>
    </defs>
  </svg>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 w-full h-full border border-[#D0CDC5]">
    
    <!-- Cell 1: Phone-checking -->
    <div class="sketch-cell relative min-h-[350px] p-8 flex flex-col justify-end group border-b border-[#D0CDC5] md:border-r" data-index="0">
      <div class="absolute inset-0 w-full h-full p-4 pointer-events-none">
        <svg class="w-full h-full overflow-visible" viewBox="0 0 320 320" preserveAspectRatio="xMidYMid meet">
          <g filter="url(#hand-tremor)">
            <!-- 1. Desk & Chair -->
            <rect id="cell1-desk" x="30" y="230" width="260" height="20" rx="2" stroke="#1a1a1a" stroke-width="1.5" fill="#fafaf9" />
            <line x1="40" y1="236" x2="280" y2="236" stroke="#E5E5E5" stroke-width="0.5" />
            <line x1="40" y1="240" x2="280" y2="240" stroke="#E5E5E5" stroke-width="0.5" />
            <line x1="40" y1="244" x2="280" y2="244" stroke="#E5E5E5" stroke-width="0.5" />
            
            <rect id="cell1-chair" x="105" y="140" width="30" height="90" rx="4" stroke="#6B6B6B" stroke-width="1.5" fill="none" />
            <line x1="100" y1="228" x2="140" y2="228" stroke="#6B6B6B" stroke-width="1" />

            <!-- 2. Human Figure -->
            <path id="cell1-head" class="draw-path" d="M 126 118 C 124 112, 127 109, 131 107 C 130 105, 128 103, 129 101 C 130 99, 131 98, 132 97 C 132 94, 130 91, 127 89 C 125 88, 124 86, 127 83 C 129 80, 133 77, 138 77 C 144 76, 149 79, 151 83 C 152 88, 151 93, 149 96 C 146 101, 141 107, 136 112 C 132 115, 129 118, 128 120" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <path id="cell1-torso" class="draw-path" d="M 128 120 C 122 130, 118 145, 120 160 C 122 175, 130 185, 135 190 C 140 192, 145 190, 148 186 C 146 180, 142 170, 140 160 C 138 148, 135 135, 132 125 C 130 120, 128 118, 126 118" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <path id="cell1-rightarm" class="draw-path" d="M 105 140 C 100 150, 90 160, 85 170 C 83 175, 80 178, 80 180 C 82 185, 88 195, 95 205 C 100 212, 105 218, 110 220 C 112 221, 115 223, 117 225 C 120 227, 124 227, 126 224" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <path id="cell1-leftarm" class="draw-path" d="M 130 138 C 135 150, 142 165, 150 175 C 152 180, 155 183, 155 185 C 153 190, 150 200, 148 210 C 147 215, 146 218, 145 220 C 144 222, 143 224, 145 225" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <path id="cell1-legs" class="draw-path" d="M 146 186 C 148 195, 150 205, 150 215 C 150 225, 148 235, 145 245 C 142 250, 138 255, 140 260 C 142 265, 145 268, 148 270" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />

            <!-- 3. Phone and Disruption Effects -->
            <g id="cell1-phone" class="cyan-accent" transform="translate(230,90) rotate(25)">
              <rect x="-25" y="-15" width="50" height="30" rx="6" stroke="#079AED" stroke-width="2" fill="none" />
              <rect x="-20" y="-10" width="40" height="20" rx="4" stroke="#079AED" stroke-width="1" stroke-dasharray="3 3" fill="rgba(7,154,237,0.05)" />
              <circle cx="0" cy="-15" r="2.5" fill="#079AED" />
              <path d="M -25 -10 L -30 -12 L -28 -8" stroke="#079AED" stroke-width="1" fill="none" />
              <path d="M 25 -5 L 30 -7 L 28 -3" stroke="#079AED" stroke-width="1" fill="none" />
            </g>

            <path id="cell1-zigzag1" class="draw-path cyan-accent" d="M 210 105 L 190 115 L 175 100 L 155 120 L 145 130" stroke="#079AED" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            <path id="cell1-zigzag2" class="draw-path cyan-accent" d="M 215 110 L 195 125 L 180 110 L 160 135" stroke="#079AED" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />

            <path id="cell1-starburst" class="cyan-accent" d="M 145 130 L 138 122 M 145 130 L 136 128 M 145 130 L 140 118 M 145 130 L 148 118 M 145 130 L 152 122 M 145 130 L 150 128" stroke="#079AED" stroke-width="1" fill="none" stroke-linecap="round" stroke-linejoin="round" />

            <g class="cell1-debris cyan-accent">
              <circle id="cell1-debris1" cx="135" cy="115" r="2" fill="#079AED" />
              <circle id="cell1-debris2" cx="150" cy="112" r="1.5" fill="#079AED" />
              <circle id="cell1-debris3" cx="140" cy="108" r="2.5" fill="#079AED" />
              <rect id="cell1-debris4" x="148" y="118" width="3" height="3" fill="#079AED" />
            </g>
          </g>
        </svg>
      </div>
      <div class="mt-auto flex flex-col z-10 relative pointer-events-none">
        <span class="text-[56px] text-[#1a1a1a] font-['Instrument_Serif'] leading-none">63%</span>
        <h3 class="text-[10px] uppercase tracking-[0.12em] text-[#6B6B6B] mt-3 font-['Inter'] font-semibold">Phone-checking</h3>
        <p class="text-[10px] italic text-[#999999] mt-1 font-['Inter'] -rotate-[0.5deg] origin-left">High environmental friction.</p>
      </div>
    </div>

    <!-- Cell 2: Avoidance -->
    <div class="sketch-cell relative min-h-[350px] p-8 flex flex-col justify-end group border-b border-[#D0CDC5]" data-index="1">
      <div class="absolute inset-0 w-full h-full p-4 pointer-events-none">
        <svg class="w-full h-full overflow-visible" viewBox="0 0 320 320" preserveAspectRatio="xMidYMid meet">
          <g filter="url(#hand-tremor)">
            <!-- Solid Anchor -->
            <circle class="draw-path draw-fill" cx="240" cy="160" r="40" stroke="#1a1a1a" stroke-width="2" fill="url(#hatch-dark)" />
            
            <!-- Hollow Learner -->
            <circle class="draw-path idle-hollow" cx="80" cy="160" r="20" stroke="#1a1a1a" stroke-width="2" fill="none" />
            
            <!-- Tension lines -->
            <g class="idle-tension cyan-accent">
              <line class="draw-path" x1="200" y1="160" x2="120" y2="160" stroke="#079AED" stroke-width="1" stroke-linecap="round" />
              <line class="draw-path" x1="198" y1="145" x2="135" y2="145" stroke="#079AED" stroke-width="1" stroke-linecap="round" />
              <line class="draw-path" x1="198" y1="175" x2="135" y2="175" stroke="#079AED" stroke-width="1" stroke-linecap="round" />
              <line class="draw-path" x1="190" y1="130" x2="150" y2="130" stroke="#079AED" stroke-width="1" stroke-linecap="round" />
              <line class="draw-path" x1="190" y1="190" x2="150" y2="190" stroke="#079AED" stroke-width="1" stroke-linecap="round" />
            </g>

            <!-- Dashed arc -->
            <path class="draw-path" d="M 240 100 A 60 60 0 0 0 240 220" stroke="#6B6B6B" stroke-width="2" stroke-dasharray="4 6" fill="none" stroke-linecap="round" />
          </g>
        </svg>
      </div>
      <div class="mt-auto flex flex-col z-10 relative pointer-events-none">
        <span class="text-[56px] text-[#1a1a1a] font-['Instrument_Serif'] leading-none">41%</span>
        <h3 class="text-[10px] uppercase tracking-[0.12em] text-[#6B6B6B] mt-3 font-['Inter'] font-semibold">Avoidance</h3>
        <p class="text-[10px] italic text-[#999999] mt-1 font-['Inter'] -rotate-[0.5deg] origin-left">Involuntary study correlation.</p>
      </div>
    </div>

    <!-- Cell 3: Environment Prep -->
    <div class="sketch-cell relative min-h-[350px] p-8 flex flex-col justify-end group border-b md:border-b-0 border-[#D0CDC5] md:border-r" data-index="2">
      <div class="absolute inset-0 w-full h-full p-4 pointer-events-none">
        <svg class="w-full h-full overflow-visible" viewBox="0 0 320 320" preserveAspectRatio="xMidYMid meet">
          <g filter="url(#hand-tremor)">
            <!-- Dashed frame -->
            <rect class="draw-path" x="100" y="60" width="120" height="200" stroke="#6B6B6B" stroke-width="2" stroke-dasharray="6 4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            
            <!-- Filled volume (27% height = 54px) -->
            <rect class="draw-path draw-fill cyan-accent" x="100" y="206" width="120" height="54" stroke="#079AED" stroke-width="2" fill="url(#hatch-cyan)" stroke-linecap="round" stroke-linejoin="round" />
            
            <!-- Scattered blocks -->
            <rect class="draw-path idle-scatter" x="60" y="240" width="20" height="20" stroke="#1a1a1a" stroke-width="2" fill="none" transform="rotate(-15 70 250)" stroke-linecap="round" stroke-linejoin="round" />
            <rect class="draw-path idle-scatter" x="240" y="245" width="15" height="15" stroke="#1a1a1a" stroke-width="2" fill="none" transform="rotate(25 247.5 252.5)" stroke-linecap="round" stroke-linejoin="round" />
          </g>
        </svg>
      </div>
      <div class="mt-auto flex flex-col z-10 relative pointer-events-none">
        <span class="text-[56px] text-[#1a1a1a] font-['Instrument_Serif'] leading-none">27%</span>
        <h3 class="text-[10px] uppercase tracking-[0.12em] text-[#6B6B6B] mt-3 font-['Inter'] font-semibold">Environment Prep</h3>
        <p class="text-[10px] italic text-[#999999] mt-1 font-['Inter'] -rotate-[0.5deg] origin-left">Low ritualization of learning.</p>
      </div>
    </div>

    <!-- Cell 4: Abrupt Drop -->
    <div class="sketch-cell relative min-h-[350px] p-8 flex flex-col justify-end group" data-index="3">
      <div class="absolute inset-0 w-full h-full p-4 pointer-events-none">
        <svg class="w-full h-full overflow-visible" viewBox="0 0 320 320" preserveAspectRatio="xMidYMid meet">
          <g filter="url(#hand-tremor)">
            <!-- Main bar (85%) -->
            <path class="draw-path draw-fill" d="M 40 140 L 244 140 L 240 145 L 244 150 L 240 155 L 244 160 L 40 160 Z" stroke="#1a1a1a" stroke-width="2" fill="url(#hatch-dark)" stroke-linecap="round" stroke-linejoin="round" />
            
            <!-- Broken piece (15%) -->
            <g class="idle-bob cyan-accent" transform="rotate(-25 254 150)">
              <path class="draw-path draw-fill" d="M 254 140 L 290 140 L 290 160 L 254 160 L 258 155 L 254 150 L 258 145 Z" stroke="#079AED" stroke-width="2" fill="url(#dots-cyan)" stroke-linecap="round" stroke-linejoin="round" />
            </g>
            
            <!-- Fragments -->
            <g class="idle-frag cyan-accent">
              <polygon class="draw-path" points="248,140 252,138 250,144" stroke="#079AED" stroke-width="1" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              <rect class="draw-path" x="246" y="150" width="4" height="4" stroke="#079AED" stroke-width="1" fill="none" stroke-linecap="round" stroke-linejoin="round" />
              <rect class="draw-path" x="250" y="160" width="3" height="3" stroke="#079AED" stroke-width="1" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </g>
          </g>
        </svg>
      </div>
      <div class="mt-auto flex flex-col z-10 relative pointer-events-none">
        <span class="text-[56px] text-[#1a1a1a] font-['Instrument_Serif'] leading-none">15%</span>
        <h3 class="text-[10px] uppercase tracking-[0.12em] text-[#6B6B6B] mt-3 font-['Inter'] font-semibold">Abrupt Drop</h3>
        <p class="text-[10px] italic text-[#999999] mt-1 font-['Inter'] -rotate-[0.5deg] origin-left">Environmental distractions.</p>
      </div>
    </div>

  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:ital,wght@0,300;0,400;0,600;1,400&display=swap');

  /* Premium Paper Background */
  .paper-texture {
    position: relative;
  }
  .paper-texture::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, #1a1a1a 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0.05;
  }

  /* Hover Effects */
  .cyan-accent {
    transition: filter 0.3s ease;
  }
  .sketch-cell:hover .cyan-accent {
    filter: drop-shadow(0px 0px 4px rgba(7, 154, 237, 0.4));
  }

  /* Setup initial state for drawing */
  .draw-fill {
    fill-opacity: 0;
  }
  .draw-path {
    vector-effect: non-scaling-stroke;
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

<script>
  function initEditorialDashboard() {
    if (typeof gsap === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    const wrapper = document.getElementById("editorial-dashboard");
    const cells = document.querySelectorAll(".sketch-cell");
    if (!wrapper || cells.length === 0) return;

    let idleTimelines: gsap.core.Timeline[] = [];

    // --- 1. Path Length Setup & Scroll Entrance ---
    cells.forEach((cell, index) => {
      const paths = cell.querySelectorAll(".draw-path");
      
      paths.forEach((p) => {
        let length = 100;
        if (p instanceof SVGPathElement) {
          length = p.getTotalLength();
        } else if (p instanceof SVGRectElement) {
          length = (parseFloat(p.getAttribute('width')||'0') + parseFloat(p.getAttribute('height')||'0')) * 2;
        } else if (p instanceof SVGCircleElement) {
          length = 2 * Math.PI * parseFloat(p.getAttribute('r')||'0');
        } else if (p instanceof SVGLineElement) {
          const x1 = parseFloat(p.getAttribute('x1')||'0');
          const y1 = parseFloat(p.getAttribute('y1')||'0');
          const x2 = parseFloat(p.getAttribute('x2')||'0');
          const y2 = parseFloat(p.getAttribute('y2')||'0');
          length = Math.hypot(x2-x1, y2-y1);
        } else if (p instanceof SVGPolygonElement) {
          length = 100; // approximation
        }
        
        gsap.set(p, { strokeDasharray: length + 1, strokeDashoffset: length + 1 });
      });

      // ScrollTrigger Entrance
      if (index === 0) {
        // --- CELL 1 SPECIFIC TIMELINE ---
        gsap.set("#cell1-desk", { opacity: 0, y: 10 });
        gsap.set("#cell1-chair", { opacity: 0 });
        gsap.set("#cell1-phone", { opacity: 0, x: 50 });
        gsap.set("#cell1-starburst", { opacity: 0, scale: 0 });
        gsap.set(".cell1-debris", { opacity: 0 });

        ScrollTrigger.create({
          trigger: wrapper,
          start: "top 80%",
          once: true,
          onEnter: () => {
            const tl = gsap.timeline();
            tl.to("#cell1-desk", { opacity: 1, y: 0, duration: 0.3 }, 0)
              .to("#cell1-chair", { opacity: 1, duration: 0.2 }, 0)
              .to("#cell1-head", { strokeDashoffset: 0, duration: 0.5 }, 0.2)
              .to("#cell1-torso", { strokeDashoffset: 0, duration: 0.5 }, 0.5)
              .to("#cell1-rightarm", { strokeDashoffset: 0, duration: 0.4 }, 0.8)
              .to("#cell1-leftarm", { strokeDashoffset: 0, duration: 0.4 }, 1.0)
              .to("#cell1-legs", { strokeDashoffset: 0, duration: 0.3 }, 1.2)
              .to("#cell1-phone", { opacity: 1, x: 0, duration: 0.4, ease: "back.out(1.2)" }, 1.5)
              .to(["#cell1-zigzag1", "#cell1-zigzag2"], { strokeDashoffset: 0, duration: 0.3 }, 1.8)
              .to("#cell1-starburst", { opacity: 1, scale: 1.2, duration: 0.2 }, 2.0)
              .to(["#cell1-debris1", "#cell1-debris2", "#cell1-debris3", "#cell1-debris4"], { opacity: 1, duration: 0.15, stagger: 0.05 }, 2.1);
          }
        });
      } else {
        // --- GENERIC TIMELINE FOR CELLS 2, 3, 4 ---
        ScrollTrigger.create({
          trigger: wrapper,
          start: "top 80%",
          once: true,
          onEnter: () => {
            gsap.to(paths, {
              strokeDashoffset: 0,
              duration: 1.8,
              ease: "power2.out",
              stagger: 0.15,
              delay: index * 0.2
            });

            // Fade fills naturally as strokes draw
            const fills = cell.querySelectorAll(".draw-fill");
            if(fills.length > 0) {
              gsap.to(fills, {
                fillOpacity: 1,
                duration: 1.5,
                ease: "power1.inOut",
                delay: index * 0.2 + 0.5
              });
            }
          }
        });
      }

      // QuickTo Hover scaling
      const xTo = gsap.quickTo(cell, "scale", { duration: 0.4, ease: "power3" });
      cell.addEventListener("mouseenter", () => xTo(1.02));
      cell.addEventListener("mouseleave", () => xTo(1));
    });

    // --- 2. Idle Animations (Continuous Subtle Loops) ---
    
    // Cell 1: Interrupted Focus
    const idleTl = gsap.timeline({ repeat: -1, delay: 0.5 });
    idleTl
      .to("#cell1-phone", { y: -3, duration: 1.5, ease: "sine.inOut", yoyo: true, repeat: 0 })
      .to("#cell1-zigzag1", { opacity: 0.5, duration: 0.6, yoyo: true, repeat: 0 }, "-=1.2")
      .to("#cell1-zigzag2", { opacity: 0.5, duration: 0.6, yoyo: true, repeat: 0 }, "-=1.2")
      .to("#cell1-starburst", { scale: 1.0, duration: 0.8, yoyo: true, repeat: 0 }, "-=1.2")
      .to("#cell1-debris1", { x: 2, y: -2, duration: 2, ease: "sine.inOut" }, 0)
      .to("#cell1-debris2", { x: -1, y: 1, duration: 2, ease: "sine.inOut" }, 0)
      .to("#cell1-debris3", { x: -2, y: -1, duration: 2, ease: "sine.inOut" }, 0)
      .to("#cell1-debris4", { x: 1.5, y: 1.5, duration: 2, ease: "sine.inOut" }, 0);
    idleTimelines.push(idleTl);

    // Cell 2: Hollow drifts & tension stretch
    const hollow = document.querySelector(".idle-hollow");
    const tension = document.querySelectorAll(".idle-tension");
    if (hollow && tension) {
      const t2 = gsap.timeline({ repeat: -1, yoyo: true });
      t2.to(hollow, { x: -3, duration: 2, ease: "sine.inOut" }, 0);
      t2.to(tension, { scaleX: 1.05, transformOrigin: "left center", duration: 2, ease: "sine.inOut" }, 0);
      idleTimelines.push(t2);
    }

    // Cell 3: Scattered blocks rotate
    const scatters = document.querySelectorAll(".idle-scatter");
    if (scatters.length) {
      idleTimelines.push(gsap.to(scatters, { rotation: "+=3", transformOrigin: "center", duration: 3, yoyo: true, repeat: -1, ease: "sine.inOut" }));
    }

    // Cell 4: Broken piece bobs & fragments drift
    const bob = document.querySelector(".idle-bob");
    const frag = document.querySelector(".idle-frag");
    if (bob && frag) {
      const t4 = gsap.timeline({ repeat: -1, yoyo: true });
      t4.to(bob, { y: -2, rotation: "+=2", transformOrigin: "center", duration: 2.5, ease: "sine.inOut" }, 0);
      t4.to(frag, { y: 2, x: 1, duration: 2.5, ease: "sine.inOut" }, 0);
      idleTimelines.push(t4);
    }

    // --- 3. IntersectionObserver (Pause off-screen) ---
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          idleTimelines.forEach(tl => tl.play());
        } else {
          idleTimelines.forEach(tl => tl.pause());
        }
      });
    }, { threshold: 0.1 });
    io.observe(wrapper);

    // Cleanup
    document.addEventListener('astro:page-unload', () => {
      io.disconnect();
      idleTimelines.forEach(tl => tl.kill());
    }, { once: true });
  }

  document.addEventListener('DOMContentLoaded', initEditorialDashboard);
  document.addEventListener('astro:page-load', initEditorialDashboard);
</script>
