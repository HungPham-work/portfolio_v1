---
import { ui, defaultLang, useTranslations } from '../../i18n/utils';

interface Props {
  lang: keyof typeof ui;
  t: ReturnType<typeof useTranslations>;
}

const { lang, t } = Astro.props;
---
<div class="not-prose my-12 pos-map-fade">
  <div style="background: #F5F4F0; border-radius: 12px; padding: 2rem;">

    <div style="margin-bottom: 1rem;">
      <span style="font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #444444; font-weight: 600;">{t('tiktok.map.title')}</span>
      <p style="font-family: var(--font-sans); font-size: 12px; color: #6B6B6B; margin: 4px 0 0;">{t('tiktok.map.subtitle')}</p>
    </div>

    <svg class="pos-map" viewBox="0 0 560 440" width="100%" xmlns="http://www.w3.org/2000/svg">

      <!-- Axis lines -->
      <line x1="40" y1="220" x2="520" y2="220"
            stroke="#D0CDC5" stroke-width="1"/>
      <line x1="280" y1="20" x2="280" y2="420"
            stroke="#D0CDC5" stroke-width="1"/>

      <!-- Quadrant labels (light, background) -->
      <text x="60" y="60" font-family="var(--font-sans)" font-size="11"
            fill="#E0DDD8" text-anchor="start">{t('tiktok.map.searchTrust')}</text>
      <text x="380" y="60" font-family="var(--font-sans)" font-size="11"
            fill="#E0DDD8" text-anchor="start">{t('tiktok.map.contentTrust')}</text>
      <text x="60" y="410" font-family="var(--font-sans)" font-size="11"
            fill="#E0DDD8" text-anchor="start">{t('tiktok.map.searchMass')}</text>
      <text x="380" y="410" font-family="var(--font-sans)" font-size="11"
            fill="#E0DDD8" text-anchor="start">{t('tiktok.map.contentMass')}</text>

      <!-- Axis labels -->
      <text x="44" y="214" font-family="var(--font-sans)" font-size="13"
            fill="#6B6B6B" text-anchor="start">{t('tiktok.map.search')}</text>
      <text x="460" y="214" font-family="var(--font-sans)" font-size="13"
            fill="#6B6B6B" text-anchor="start">{t('tiktok.map.content')}</text>
      <text x="286" y="38" font-family="var(--font-sans)" font-size="13"
            fill="#6B6B6B">{t('tiktok.map.official')}</text>
      <text x="286" y="414" font-family="var(--font-sans)" font-size="13"
            fill="#6B6B6B">{t('tiktok.map.mass')}</text>

      <!-- Lazada dot -->
      <circle cx="160" cy="90" r="10"
              fill="#6B6B6B" opacity="0.6"/>
      <text x="178" y="94" font-family="var(--font-sans)" font-size="14"
            fill="#444444">Lazada</text>

      <!-- Shopee dot -->
      <circle cx="180" cy="260" r="10" fill="#EE4D2D"/>
      <text x="198" y="264" font-family="var(--font-sans)" font-size="14"
            fill="#EE4D2D">Shopee</text>

      <!-- TikTok Shop dot (current) -->
      <circle cx="420" cy="300" r="10" fill="#EE1D52"/>
      <text x="376" y="336" font-family="var(--font-sans)" font-size="14"
            fill="#EE1D52">TikTok Shop</text>

      <!-- Drift arrow: current position → mall strategy (toward trust) -->
      <path d="M 420 300 C 420 240 400 180 390 150"
            stroke="#EE1D52" stroke-width="2" stroke-dasharray="5 4"
            fill="none"/>
      <!-- Arrowhead -->
      <polygon points="384,154 390,138 396,154" fill="#EE1D52"/>
      <!-- Label -->
      <text x="298" y="188" font-family="var(--font-sans)" font-size="12"
            fill="#EE1D52">Mall strategy →</text>

    </svg>
  </div>
</div>

<style>
  .pos-map-fade {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    will-change: opacity, transform;
  }
  
  .pos-map-fade.in-view {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 480px) {
    .pos-map-fade > div {
      padding: 1rem;
      border-radius: 8px;
    }
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.pos-map-fade').forEach((section) => {
    observer.observe(section);
  });
</script>
